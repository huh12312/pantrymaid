{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@pantrymaid/shared": ["../../packages/shared/src"]
    }
  },
  "include": ["src"],
  "exclude": ["src/test"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
