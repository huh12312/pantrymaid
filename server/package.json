{
  "name": "@pantrymaid/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../.env run --watch src/index.ts",
    "build": "tsc",
    "start": "bun run dist/index.js",
    "lint": "eslint src/ --ext .ts",
    "test": "echo 'Server tests configured for Phase 2' && exit 0",
    "db:generate": "drizzle-kit generate",
    "db:push": "bun --env-file=../.env drizzle-kit push",
    "seed": "bun --env-file=../.env run src/db/seed.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/groq": "^3.0.35",
    "@ai-sdk/openai": "^3.0.53",
    "@hono/node-server": "^2.0.0",
    "@hono/zod-validator": "^0.4.1",
    "@pantrymaid/shared": "workspace:*",
    "ai": "^6.0.168",
    "better-auth": "^1.6.9",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.15",
    "openai": "^4.77.0",
    "postgres": "^3.4.9",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/bun": "^1.3.13",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8.56.0",
    "testcontainers": "^11.14.0",
    "typescript": "^5.3.3"
  }
}
