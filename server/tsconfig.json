{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ESNext"],
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "bundler",
    "types": ["bun-types"],
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@pantrymaid/shared": ["../packages/shared/src"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["src/test", "src/db/seed.ts"]
}
